<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% if title %}{{ title }} — {% endif %}Berkeley Interim Housing Analysis</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Data analysis of police calls near four University Avenue interim housing conversions in Berkeley.{% endif %}" />
  <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}" />
</head>
<body>
  <header class="site-header">
    <nav class="nav-inner">
      <a class="site-name" href="{{ '/' | url }}">Berkeley Interim Housing Analysis</a>
      <ul class="nav-links">
        <li><a href="{{ '/findings/' | url }}">Findings</a></li>
        <li><a href="{{ '/context/' | url }}">How We Got Here</a></li>
        <li><a href="{{ '/benchmark/' | url }}">Benchmark</a></li>
        <li><a href="{{ '/methodology/' | url }}">Methodology</a></li>
        <li><a href="{{ '/maps/' | url }}">Maps</a></li>
        <li><a href="{{ '/data-sources/' | url }}">Data</a></li>
      </ul>
    </nav>
  </header>

  <main class="page-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>Berkeley public data analysis &mdash; non-partisan, open source.</p>
      <p class="footer-meta">
        Source: Berkeley Open Data Portal &middot;
        <a href="https://github.com/{{ site.github_repo }}">GitHub</a>
        {% if build %}
        &middot; Built {{ build.build_timestamp | truncate(10, true, "") }}
        &middot; <span title="git {{ build.git_sha }}">{{ build.git_sha }}</span>
        {% endif %}
      </p>
    </div>
  </footer>

  <script>window.BASE_PATH = "{{ '/' | url }}";</script>
  <script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@observablehq/plot@0.6/dist/plot.umd.min.js"></script>
  {% for s in scripts %}
  <script src="{{ s | url }}" type="module"></script>
  {% endfor %}
</body>
</html>
